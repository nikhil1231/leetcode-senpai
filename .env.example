# Docker Compose reads this file after you copy it to `.env`.
# Keep `.env` private; it may contain machine-specific credential paths.

# Host path to your Firebase service-account JSON key.
FIREBASE_SERVICE_ACCOUNT_JSON=C:\Users\Nikhil\secrets\firebase-service-account.json

# Local browser URL will be http://127.0.0.1:${HOST_PORT}
HOST_PORT=8000

# Optional coach model. The app defaults to OpenAI GPT-5.6 Luna.
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.6-luna
OPENAI_API_KEY=

# Optional fallback/alternate provider selectable in Settings.
GEMINI_API_KEY=
